# Copia este archivo a .env y completa con tus valores reales.
# .env NUNCA se commitea (ver .gitignore).

# --- Aplicacion ---
ENV=dev
APP_NAME=Riesgo API
LOG_LEVEL=INFO

# --- Base de datos ---
# En desarrollo: SQLite local. En produccion (Render): usa una ruta persistente.
DATABASE_URL=sqlite:///./risk.db

# --- APIs externas ---
# FRED: registrate gratis en https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=tu_clave_fred_aqui

# --- Cache transparente ---
# Minutos de validez del cache de precios antes de re-consultar yfinance.
CACHE_TTL_MINUTES=1440

# --- Modelo ML ---
ML_MODEL_PATH=app/ml/model.joblib
ML_DEFAULT_TICKER=AAPL
